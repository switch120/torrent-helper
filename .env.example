[App_Settings]
# Leave blank if you don't want to retain torrent history when cleaned
TORRENT_HISTORY=true

[Docker]
OPENVPN_PROVIDER=PIA
OPENVPN_CONFIG=US East
OPENVPN_USERNAME=
OPENVPN_PASSWORD=
OPENVPN_OPTS=--inactive 3600 --ping 10 --ping-exit 60
WEBPROXY_ENABLED=false
LOCAL_NETWORK=192.168.0.0/16

# Release Hub
TMDB_API_KEY=
TMDB_READ_ACCESS_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TORRENT_RERANK_ENABLED=false
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_CLIENT_ID=
RELEASE_DB_USER=release
RELEASE_DB_PASSWORD=release
RELEASE_DB_NAME=release_hub
RELEASE_DB_PORT=5433
RELEASE_API_PORT=3001
RELEASE_WEB_PORT=4200
RELEASE_WEB_ORIGIN=http://localhost:4200
PROWLARR_BASE_URL=http://prowlarr:9696
PROWLARR_API_KEY=
PROWLARR_PORT=9696
TRANSMISSION_WEB_PORT=9091
TRANSMISSION_RPC_HOST=torrentHost
TRANSMISSION_RPC_PORT=9091
TRANSMISSION_RPC_USERNAME=
TRANSMISSION_RPC_PASSWORD=
HOST_UID=501
HOST_GID=20
