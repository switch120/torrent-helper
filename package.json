{
  "name": "torrent-helper",
  "version": "1.0.0",
  "description": "Docker-first Transmission VPN and release hub utilities.",
  "scripts": {
    "diagnose": "bash scripts/diagnose-transmission.sh",
    "lint": "eslint \"apps/**/*.ts\"",
    "knip": "knip --include files,dependencies,unlisted --no-config-hints",
    "precommit:check": "npm run knip && npm run lint && git diff --check",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "author": "Scott Byers",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "knip": "^6.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
